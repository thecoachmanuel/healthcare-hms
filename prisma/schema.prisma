

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  INCOMPLETE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
}

enum PaymentTransactionStatus {
  INITIATED
  SUCCESS
  FAILED
}

enum HospitalDomainType {
  SUBDOMAIN
  CUSTOM
}

model Hospital {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  active      Boolean  @default(true)

  domains     HospitalDomain[]
  subscriptions Subscription[]
  transactions PaymentTransaction[]

  patients    Patient[]
  doctors     Doctor[]
  working_days WorkingDays[]
  staff       Staff[]
  wards       Ward[]
  departments Department[]
  appointments Appointment[]
  payments    Payment[]
  patient_bills PatientBills[]
  services    Services[]
  lab_tests   LabTest[]
  lab_units   LabUnit[]
  specializations DoctorSpecialization[]
  site_settings SiteSettings[]
  notifications Notification[]
  audit_logs  AuditLog[]
  ratings     Rating[]
  prescriptions Prescription[]
  prescription_items PrescriptionItem[]
  admissions  InpatientAdmission[]
  medical_records MedicalRecords[]
  vital_signs VitalSigns[]
  diagnoses   Diagnosis[]
  medication_administrations MedicationAdministration[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model HospitalDomain {
  id            Int      @id @default(autoincrement())
  hospital_id   Int
  domain        String   @unique
  type          HospitalDomainType @default(SUBDOMAIN)
  verified      Boolean  @default(false)
  verification_token String?

  hospital      Hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([hospital_id])
}

model Plan {
  id                Int      @id @default(autoincrement())
  name              String
  currency          String   @default("NGN")
  monthly_price_kobo Int
  yearly_price_kobo  Int
  max_admins        Int
  max_staff         Int
  active            Boolean  @default(true)

  subscriptions     Subscription[]

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@unique([name])
}

model Subscription {
  id                   Int      @id @default(autoincrement())
  hospital_id          Int
  plan_id              Int
  interval             BillingInterval
  status               SubscriptionStatus @default(INCOMPLETE)
  current_period_start DateTime?
  current_period_end   DateTime?
  cancel_at_period_end Boolean @default(false)
  paystack_customer_code String?
  paystack_subscription_code String?

  hospital             Hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  plan                 Plan     @relation(fields: [plan_id], references: [id], onDelete: Restrict)
  transactions         PaymentTransaction[]

  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([hospital_id])
  @@index([plan_id])
}

model PaymentTransaction {
  id              Int      @id @default(autoincrement())
  hospital_id     Int
  subscription_id Int?
  provider        PaymentProvider @default(PAYSTACK)
  reference       String   @unique
  amount_kobo     Int
  currency        String   @default("NGN")
  status          PaymentTransactionStatus @default(INITIATED)
  raw             Json?

  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
  @@index([subscription_id])
}



enum Role {
  ADMIN
  NURSE
  DOCTOR
  LAB_SCIENTIST
  LAB_TECHNICIAN
  LAB_RECEPTIONIST
  PHARMACIST
  RECORD_OFFICER
  RECEPTIONIST
  PATIENT
  CASHIER
}

enum ServiceCategory {
  GENERAL
  LAB_TEST
  MEDICATION
}

enum Status {
  ACTIVE
  INACTIVE
  DORMANT
}

enum JOBTYPE {
  FULL
  PART  
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentStatus {
  PENDING
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  CASH
  CARD
}

enum PaymentStatus {
  PAID
  UNPAID
  PART
}


model Patient {
  id                       String   @id //clerk userId
  hospital_id              Int      @default(1)
  hospital_number          String?
  first_name               String
  last_name                String
  date_of_birth            DateTime
  gender                   Gender @default(MALE)
  phone                    String
  email                    String   @unique
  marital_status           String
  address                  String
  emergency_contact_name   String
  emergency_contact_number String
  relation                 String
  blood_group              String?
  allergies                String?
  medical_conditions       String?
  medical_history          String?
  insurance_provider       String?
  insurance_number         String?
  privacy_consent          Boolean
  service_consent          Boolean
  medical_consent          Boolean
  img                      String?
  colorCode                String?

  appointments             Appointment[]
  medical                  MedicalRecords[]
  payments                 Payment[]
  ratings                  Rating[]
  prescriptions            Prescription[]
  medication_administrations MedicationAdministration[]
  admissions               InpatientAdmission[]

  hospital                 Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id, hospital_number])
}

model Doctor {
  id                    String   @id
  hospital_id           Int      @default(1)
  email                 String   @unique
  name                  String
  specialization        String
  license_number        String
  phone                 String
  address               String
  department            String?
  ward_id               Int?
  img                   String?
  colorCode             String?
  availability_status   String?

  type                  JOBTYPE @default(FULL)
  working_days          WorkingDays[]
  appointments          Appointment[]
  ratings               Rating[]
  diagnosis             Diagnosis[] 
  prescriptions         Prescription[]
  ward                  Ward? @relation(fields: [ward_id], references: [id])
  admissions            InpatientAdmission[]

  hospital              Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([hospital_id])
}


model WorkingDays {
  id              Int   @id @default(autoincrement())
  hospital_id     Int   @default(1)
  doctor_id       String
  day             String
  start_time      String
  close_time      String

  doctor          Doctor  @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
}


model Staff {
  id            String   @id
  hospital_id   Int      @default(1)
  email         String   @unique
  name          String
  phone         String
  address       String
  department    String?
  img           String?
  license_number String?
  colorCode      String?
  lab_unit_id   Int?
  ward_id       Int?

  role          Role
  status        Status @default(ACTIVE)

  lab_unit      LabUnit? @relation(fields: [lab_unit_id], references: [id])
  ward          Ward? @relation(fields: [ward_id], references: [id])
  medication_administrations MedicationAdministration[]

  hospital      Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([hospital_id])
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
}

model Ward {
  id         Int      @id @default(autoincrement())
  hospital_id Int     @default(1)
  name       String
  department String?
  capacity   Int      @default(0)
  active     Boolean  @default(true)

  staff      Staff[]
  doctors    Doctor[]
  admissions InpatientAdmission[]

  hospital   Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id, name])
}

model InpatientAdmission {
  id                  Int              @id @default(autoincrement())
  hospital_id         Int              @default(1)
  patient_id          String
  ward_id             Int
  attending_doctor_id String?
  admitted_by_id      String?
  admitted_by_role    Role?
  status              AdmissionStatus  @default(ADMITTED)
  admitted_at         DateTime         @default(now())
  discharged_at       DateTime?
  discharge_notes     String?
  discharged_by_id    String?
  discharged_by_role  Role?

  patient             Patient          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  ward                Ward             @relation(fields: [ward_id], references: [id], onDelete: Cascade)
  attending_doctor    Doctor?          @relation(fields: [attending_doctor_id], references: [id])

  hospital             Hospital         @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([patient_id])
  @@index([ward_id])
  @@index([status])
  @@index([hospital_id])
}

model Department {
  id         Int      @id @default(autoincrement())
  hospital_id Int     @default(1)
  name       String
  active     Boolean  @default(true)

  hospital   Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id, name])
}



model Appointment {
  id                Int   @id @default(autoincrement())
  hospital_id       Int   @default(1)
  patient_id        String
  doctor_id         String
  appointment_date  DateTime
  time              String
  status            AppointmentStatus @default(PENDING)
  type              String
  note              String?
  patient           Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  doctor            Doctor   @relation(fields: [doctor_id], references: [id],  onDelete:  Cascade)

  bills             Payment[]
  medical           MedicalRecords[]

  reason            String?

  hospital          Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@index([hospital_id])
}

model Payment {
  id              Int   @id @default(autoincrement())
  hospital_id     Int   @default(1)
  bill_id         Int?
  patient_id      String
  appointment_id  Int @unique
  bill_date       DateTime
  payment_date    DateTime
  discount        Float
  total_amount    Float
  amount_paid     Float
  coverage_type   CoverageType @default(NONE)
  coverage_notes  String?
  coverage_reference String?
  payment_reason  String?

  payment_method  PaymentMethod @default(CASH)
  status          PaymentStatus @default(UNPAID)
  receipt_number  Int @default(autoincrement())

  appointment     Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  patient         Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  bills           PatientBills[]

  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
}

model PatientBills {
  id              Int   @id @default(autoincrement())
  hospital_id     Int   @default(1)
  bill_id         Int
  service_id      Int
  service_date    DateTime
  quantity        Int
  unit_cost       Float
  total_cost      Float
  payment_status  PaymentStatus @default(UNPAID)
  amount_paid     Float @default(0)
  paid_at         DateTime?
  issued_by_id    String?
  issued_by_role  Role?
  notes           String?
  service         Services @relation(fields: [service_id], references: [id])
  payment         Payment @relation(fields: [bill_id], references: [id], onDelete: Cascade)

  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
}

model LabTest {
  id            Int   @id @default(autoincrement())
  hospital_id   Int   @default(1)
  record_id     Int
  test_date     DateTime
  result        String
  status        String
  notes         String?
  service_id    Int
  services      Services @relation(fields: [service_id], references: [id])

  medical_record MedicalRecords  @relation(fields: [record_id], references: [id], onDelete: Cascade)

  hospital      Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([record_id, service_id])
  @@index([hospital_id])
}

model LabUnit {
  id          Int @id @default(autoincrement())
  hospital_id Int @default(1)
  name        String
  active      Boolean @default(true)

  staff       Staff[]
  services    Services[]

  hospital    Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id, name])
}

model MedicalRecords {
  id              Int @id @default(autoincrement())
  hospital_id     Int @default(1)
  patient_id      String
  appointment_id  Int
  doctor_id       String
  treatment_plan  String?
  prescriptions   String?
  lab_request     String?

  appointment     Appointment @relation(fields: [appointment_id], references: [id], onDelete: Cascade)
  patient         Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  lab_test        LabTest[]
  notes           String?
 
  vital_signs     VitalSigns[]
  diagnosis       Diagnosis[]

  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
}

model VitalSigns {
  id                Int      @id @default(autoincrement())
  hospital_id       Int      @default(1)
  patient_id        String
  medical_id        Int  
  medical           MedicalRecords @relation(fields: [medical_id], references: [id], onDelete: Cascade)
  body_temperature   Float    
  systolic          Int       
  diastolic         Int     
  heartRate         String      
  respiratory_rate   Int?       
  oxygen_saturation  Int?     
  weight            Float     
  height            Float     

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  hospital          Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  @@index([hospital_id])
}

model Diagnosis {
  id              Int      @id @default(autoincrement())
  hospital_id     Int      @default(1)
  patient_id      String
  medical_id      Int
  doctor_id       String
  doctor          Doctor    @relation(fields: [doctor_id], references: [id])
  symptoms        String    
  diagnosis       String    
  notes           String?   
  prescribed_medications String?   
  follow_up_plan   String?

  medical          MedicalRecords @relation(fields: [medical_id ], references: [id], onDelete: Cascade)

  hospital         Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([hospital_id])
}

model AuditLog {
  id          Int   @id @default(autoincrement())
  hospital_id Int   @default(1)
  user_id     String
  record_id   String
  action      String
  details     String?
  model       String

  hospital    Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([hospital_id])
}

model Notification {
  id          Int   @id @default(autoincrement())
  hospital_id Int   @default(1)
  user_id     String
  title       String
  body        String
  read        Boolean @default(false)

  hospital    Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([hospital_id])
}

model SiteSettings {
  id          Int    @id @default(autoincrement())
  hospital_id Int    @default(1)
  site_name   String
  site_title  String?
  logo_url    String?
  homepage_title String?
  homepage_subtitle String?
  homepage_text  String?
  updated_by_id String?

  hospital    Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id])
}

model Rating {
  id         Int      @id @default(autoincrement())
  hospital_id Int     @default(1)
  staff_id   String
  patient_id String
  rating     Int      
  comment    String?  

  doctor     Doctor   @relation(fields: [staff_id], references: [id], onDelete: Cascade)
  patient    Patient  @relation(fields: [patient_id], references: [id], onDelete: Cascade)

  hospital   Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([hospital_id])
}

model Services {
  id             Int    @id @default(autoincrement())
  hospital_id    Int    @default(1)
  service_name    String
  description     String
  price           Float
  category        ServiceCategory @default(GENERAL)
  lab_unit_id     Int?
  created_by_id   String?
  created_by_role Role?
  labtests        LabTest[]
  bills           PatientBills[]
  prescription_items PrescriptionItem[]
  lab_unit        LabUnit? @relation(fields: [lab_unit_id], references: [id])

  hospital        Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([hospital_id])
}

model DoctorSpecialization {
  id          Int @id @default(autoincrement())
  hospital_id Int @default(1)
  name        String
  department  String?
  active      Boolean @default(true)

  hospital    Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([hospital_id])
  @@unique([hospital_id, name])
}

enum PrescriptionStatus {
  ISSUED
  DISPENSED
  CANCELLED
}

enum CoverageType {
  NONE
  INSURANCE
  NHIA
  WAIVER
  OTHER
}

model Prescription {
  id             Int   @id @default(autoincrement())
  hospital_id    Int   @default(1)
  patient_id     String
  doctor_id      String
  appointment_id Int?
  notes          String?
  status         PrescriptionStatus @default(ISSUED)
  patient        Patient @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  doctor         Doctor  @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
  items          PrescriptionItem[]

  hospital       Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([hospital_id])
}

model PrescriptionItem {
  id               Int @id @default(autoincrement())
  hospital_id      Int @default(1)
  prescription_id  Int
  medication_id    Int
  quantity         Int
  dosage           String?
  instructions     String?

  prescription     Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)
  medication       Services @relation(fields: [medication_id], references: [id], onDelete: Cascade)
  administrations  MedicationAdministration[]

  hospital         Hospital @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([prescription_id])
  @@index([medication_id])
  @@index([hospital_id])
}

model MedicationAdministration {
  id                    Int      @id @default(autoincrement())
  hospital_id           Int      @default(1)
  prescription_item_id  Int
  patient_id            String
  nurse_id              String
  quantity              Int
  notes                 String?
  administered_at       DateTime @default(now())

  prescription_item     PrescriptionItem @relation(fields: [prescription_item_id], references: [id], onDelete: Cascade)
  patient               Patient          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  nurse                 Staff            @relation(fields: [nurse_id], references: [id], onDelete: Cascade)

  hospital              Hospital         @relation(fields: [hospital_id], references: [id], onDelete: Restrict)

  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([patient_id])
  @@index([nurse_id])
  @@index([prescription_item_id])
  @@index([hospital_id])
}
